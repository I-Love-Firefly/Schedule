<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:views="clr-namespace:Schedule2._0.Views"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             xmlns:converters="clr-namespace:Schedule2._0.Converters"
             x:Class="Schedule2._0.Views.MainPage"
             Title="课表助手"
             BackgroundColor="{DynamicResource AppBg}"
             Shell.NavBarIsVisible="False">

    <ContentPage.Resources>
        <ResourceDictionary>
            <converters:TimeFormatConverter x:Key="TimeFormatConverter" />
            <converters:ColorOpacityConverter x:Key="ColorOpacityConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior
            StatusBarColor="{DynamicResource AppBg}"
            StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <Grid BackgroundColor="{DynamicResource AppBg}">
        <Image x:Name="BgImage"
               Aspect="AspectFill"
               IsVisible="False"
               HorizontalOptions="Fill"
               VerticalOptions="Fill" />
        <ScrollView>
            <VerticalStackLayout Padding="18,20,18,28" Spacing="18">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                    <Label Text="课表助手"
                           FontSize="34"
                           FontAttributes="Bold"
                           TextColor="{DynamicResource TextMain}"
                           VerticalOptions="End" />

                    <ImageButton Grid.Column="1"
                                 HeightRequest="42"
                                 WidthRequest="42"
                                 Padding="0"
                                 BackgroundColor="Transparent"
                                 Clicked="OnHamburgerClicked"
                                 VerticalOptions="Center">
                        <ImageButton.Source>
                            <FontImageSource FontFamily="MaterialSymbols"
                                             Glyph="&#xe5d4;"
                                             Color="{DynamicResource NavText}"
                                             Size="26" />
                        </ImageButton.Source>
                    </ImageButton>
                </Grid>

                <Button x:Name="ImportBtn"
                        Text="导入课表"
                        Clicked="OnSyncClicked"
                        HeightRequest="56"
                        CornerRadius="14"
                        BackgroundColor="{DynamicResource BtnBgMain}"
                        TextColor="{DynamicResource TextMain}"
                        FontSize="17"
                        FontAttributes="Bold"
                        Shadow="{x:Null}" />

                <CollectionView x:Name="CoursesListView"
                                SelectionMode="None"
                                Margin="0,4,0,0">
                    <CollectionView.EmptyView>
                        <Border BackgroundColor="{DynamicResource CardBg}"
                                Padding="20"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="20" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="10">
                                <Label Text="还没有课程"
                                       FontSize="20"
                                       FontAttributes="Bold" />
                                <Label Text="先通过上方按钮导入课表，主页会按星期自动展示课程。"
                                       TextColor="{DynamicResource TextSec}"
                                       LineBreakMode="WordWrap" />
                            </VerticalStackLayout>
                        </Border>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <VerticalStackLayout Spacing="10" Margin="0,0,0,10">
                                <Label Text="{Binding DayOfWeek}"
                                       IsVisible="{Binding IsDayVisible}"
                                       Margin="2,0,0,2"
                                       FontSize="16"
                                       FontAttributes="Bold"
                                       TextColor="{DynamicResource TextSec}" />

                                <SwipeView Margin="8,4,8,10">
                                    <SwipeView.RightItems>
                                        <SwipeItems Mode="Reveal">
                                            <SwipeItemView Invoked="OnDeleteCourseClicked">
                                                <Border BackgroundColor="#E14D4D"
                                                        Margin="8,0,0,0"
                                                        Padding="18,0"
                                                        MinimumWidthRequest="84"
                                                        StrokeThickness="0">
                                                    <Border.StrokeShape>
                                                        <RoundRectangle CornerRadius="18" />
                                                    </Border.StrokeShape>
                                                    <Label Text="删除"
                                                           TextColor="White"
                                                           FontAttributes="Bold"
                                                           HorizontalOptions="Center"
                                                           VerticalOptions="Center" />
                                                </Border>
                                            </SwipeItemView>
                                        </SwipeItems>
                                    </SwipeView.RightItems>

                                    <Border BackgroundColor="{Binding Source={RelativeSource AncestorType={x:Type CollectionView}}, Path=BindingContext.CardOpacity, Converter={StaticResource ColorOpacityConverter}}"
                                            Padding="14,12"
                                            Margin="0"
                                            StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="16" />
                                        </Border.StrokeShape>
                                        <Border.Shadow>
                                            <Shadow Brush="Black"
                                                    Offset="0,2"
                                                    Radius="8"
                                                    Opacity="0.12" />
                                        </Border.Shadow>
                                        <Border.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnCourseCardClicked" />
                                        </Border.GestureRecognizers>

                                        <Grid ColumnDefinitions="76,*" ColumnSpacing="12">
                                                <VerticalStackLayout Grid.Column="0"
                                                                     Spacing="2"
                                                                     VerticalOptions="Center"
                                                                     HorizontalOptions="Center">
                                                    <Label Text="{Binding StartTime, Converter={StaticResource TimeFormatConverter}}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center" />
                                                    <BoxView HeightRequest="12"
                                                             WidthRequest="1.5"
                                                             HorizontalOptions="Center"
                                                             Color="{DynamicResource TextSec}"
                                                             Opacity="1" />
                                                    <Label Text="{Binding EndTime, Converter={StaticResource TimeFormatConverter}}"
                                                           FontSize="13"
                                                           FontAttributes="Bold"
                                                           HorizontalTextAlignment="Center" />
                                                </VerticalStackLayout>

                                                <VerticalStackLayout Grid.Column="1"
                                                                     Spacing="4"
                                                                     VerticalOptions="Center">
                                                    <Label Text="{Binding Name}"
                                                           FontSize="15"
                                                           FontAttributes="Bold"
                                                           LineBreakMode="WordWrap"
                                                           MaxLines="3" />
                                                    <Label Text="{Binding Location}"
                                                           FontSize="13"
                                                           TextColor="{DynamicResource TextAccent}" />
                                                </VerticalStackLayout>
                                                </Grid>
                                            </Border>
                                </SwipeView>
                            </VerticalStackLayout>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <views:MenuView x:Name="ActionMenu"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        HorizontalAlign="Fill"
                        VerticalAlign="Start"
                        ZIndex="9998" />

        <views:MenuView x:Name="HamburgerMenu"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill"
                        HorizontalAlign="End"
                        VerticalAlign="Start"
                        IsVisible="False"
                                                 ZIndex="9999" />

                                <views:MenuView x:Name="CourseDetailMenu"
                                                                 HorizontalOptions="Fill"
                                                                 VerticalOptions="Fill"
                                                                 ZIndex="9997" />

                                                <views:MenuView x:Name="PrivacyMenu"
                                                 HorizontalOptions="Fill"
                                                 VerticalOptions="Fill"
                                                 ZIndex="10000" />
                            </Grid>
                        </ContentPage>

